import pandas as pd
import matplotlib.pyplot as plt
import seaborn as sns

sns.set_style("whitegrid")

# Data
data = {
    'Produk': ['A', 'B', 'C', 'A', 'B', 'C'],
    'Penjualan': [1500, 2300, 1800, 1700, 2100, 1900],
    'Bulan': ['Jan', 'Jan', 'Jan', 'Feb', 'Feb', 'Feb']
}
df = pd.DataFrame(data)

# Grafik 1: Bar Chart Penjualan per Produk
plt.figure(figsize=(8,5))
sns.barplot(x='Produk', y='Penjualan', data=df, estimator=sum)
plt.title('Penjualan per Produk')
plt.tight_layout()
plt.savefig('penjualan_per_produk.png', dpi=200)
plt.show()

# Grafik 2: Line Chart Tren Penjualan Bulanan
plt.figure(figsize=(8,5))
sns.lineplot(x='Bulan', y='Penjualan', data=df, hue='Produk', marker='o')
plt.title('Tren Penjualan Bulanan')
plt.tight_layout()
plt.savefig('tren_penjualan_bulanan.png', dpi=200)
plt.show()

print("Selesai! Cek panel kiri Colab, ada 2 file .png baru")
