import pandas as pd
import matplotlib.pyplot as plt

df = pd.read_csv('./data_pejualan_day1.csv')
df['Tanggal'] = pd.to_datetime(df['Tanggal'])

df_bulan = df.groupby(df['Tanggal'].dt.to_period('M'))['Total'].sum()

df_bulan.plot(kind='line', marker='o', figsize=(8,5))
plt.title('Tren Penjualan per Bulan')
plt.xlabel('Bulan')
plt.ylabel('Total Penjualan (Rp)')
plt.grid(True)
plt.show()
